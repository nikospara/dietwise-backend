<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd
		http://www.liquibase.org/xml/ns/dbchangelog-ext
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd"
>
	<changeSet id="personal_info_country" author="codex">
		<addColumn tableName="DW_PERSONAL_INFO">
			<column name="country" type="VARCHAR(2)" remarks="The ISO 3166-1 alpha-2 country code" />
		</addColumn>
	</changeSet>

	<changeSet id="alternative_ingredient_seasonality" author="codex">
		<createTable tableName="DW_ALTERNATIVE_INGREDIENT_SEASONALITY" remarks="Country-specific in-season months for alternative ingredients">
			<column name="alternative_ingredient_id" type="UUID" remarks="The alternative ingredient id">
				<constraints primaryKey="true" primaryKeyName="PK_DW_ALTERNATIVE_INGREDIENT_SEASONALITY" />
			</column>
			<column name="country" type="VARCHAR(2)" remarks="The ISO 3166-1 alpha-2 country code">
				<constraints primaryKey="true" primaryKeyName="PK_DW_ALTERNATIVE_INGREDIENT_SEASONALITY" />
			</column>
			<column name="month_from" type="INT" remarks="The first in-season month, inclusive">
				<constraints nullable="false" notNullConstraintName="NL_DW_ALTERNATIVE_INGREDIENT_SEASONALITY__MONTH_FROM" />
			</column>
			<column name="month_to" type="INT" remarks="The last in-season month, inclusive">
				<constraints nullable="false" notNullConstraintName="NL_DW_ALTERNATIVE_INGREDIENT_SEASONALITY__MONTH_TO" />
			</column>
		</createTable>
		<addForeignKeyConstraint
			baseTableName="DW_ALTERNATIVE_INGREDIENT_SEASONALITY"
			baseColumnNames="alternative_ingredient_id"
			constraintName="FK_ALTERNATIVE_INGREDIENT_SEASONALITY__ALTERNATIVE_INGREDIENT_ID__ALTERNATIVE_INGREDIENT__ID"
			referencedTableName="DW_ALTERNATIVE_INGREDIENT"
			referencedColumnNames="id"
		/>
	</changeSet>

	<changeSet id="alternative_ingredient_cost" author="codex">
		<createTable tableName="DW_ALTERNATIVE_INGREDIENT_COST" remarks="Country-specific indicative cost for alternative ingredients">
			<column name="alternative_ingredient_id" type="UUID" remarks="The alternative ingredient id">
				<constraints primaryKey="true" primaryKeyName="PK_DW_ALTERNATIVE_INGREDIENT_COST" />
			</column>
			<column name="country" type="VARCHAR(2)" remarks="The ISO 3166-1 alpha-2 country code">
				<constraints primaryKey="true" primaryKeyName="PK_DW_ALTERNATIVE_INGREDIENT_COST" />
			</column>
			<column name="cost" type="VARCHAR(3)" remarks="The indicative coarse-grained cost">
				<constraints nullable="false" notNullConstraintName="NL_DW_ALTERNATIVE_INGREDIENT_COST__COST" />
			</column>
		</createTable>
		<addForeignKeyConstraint
			baseTableName="DW_ALTERNATIVE_INGREDIENT_COST"
			baseColumnNames="alternative_ingredient_id"
			constraintName="FK_ALTERNATIVE_INGREDIENT_COST__ALTERNATIVE_INGREDIENT_ID__ALTERNATIVE_INGREDIENT__ID"
			referencedTableName="DW_ALTERNATIVE_INGREDIENT"
			referencedColumnNames="id"
		/>
	</changeSet>

	<changeSet id="recipe-statistics" author="codex">
		<createTable tableName="DW_USER_RECIPE_STATS" remarks="Per-user statistics for assessed recipes">
			<column name="user_id" type="UUID" remarks="Reference to the user">
				<constraints primaryKey="true" primaryKeyName="PK_DW_USER_RECIPE_STATS" />
			</column>
			<column name="application_id" type="VARCHAR(30)" remarks="Application id">
				<constraints primaryKey="true" primaryKeyName="PK_DW_USER_RECIPE_STATS" />
			</column>
			<column name="recipe_url" type="VARCHAR(2000)" remarks="Recipe URL as supplied for assessment">
				<constraints primaryKey="true" primaryKeyName="PK_DW_USER_RECIPE_STATS" />
			</column>
			<column name="recipe_name" type="VARCHAR(300)" remarks="Last observed recipe title" />
			<column name="times_assessed" type="INT" remarks="Number of times the user assessed this recipe" />
			<column name="last_assessed" type="TIMESTAMP" remarks="The time the user last assessed this recipe" />
		</createTable>

		<addForeignKeyConstraint
			baseTableName="DW_USER_RECIPE_STATS"
			baseColumnNames="user_id"
			constraintName="FK_DW_USER_RECIPE_STATS__USER_ID__DW_USER__ID"
			referencedTableName="DW_USER"
			referencedColumnNames="id"
		/>
	</changeSet>
</databaseChangeLog>
